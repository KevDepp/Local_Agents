{
    "name": "antigravity-connector",
    "displayName": "Antigravity Connector",
    "description": "Internal connector to script Antigravity chat interactions.",
    "version": "0.0.1",
    "publisher": "local",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onCommand:antigravityConnector.diagnostics"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "antigravityConnector.diagnostics",
                "title": "Antigravity Connector: Diagnostics"
            }
        ],
        "configuration": {
            "title": "Antigravity Connector",
            "properties": {
                "antigravityConnector.port": {
                    "type": "number",
                    "default": 17374,
                    "description": "HTTP port to listen on. Recommended: 17374 in VS Code and 17375 in Antigravity to avoid collisions."
                },
                "antigravityConnector.autoSend": {
                    "type": "boolean",
                    "default": true,
                    "description": "If true, append newline/submit immediately."
                },
                "antigravityConnector.useCDP": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, use Chrome DevTools Protocol to inject and submit chat messages."
                },
                "antigravityConnector.cdpPort": {
                    "type": "number",
                    "default": 9000,
                    "description": "CDP port to connect to (remote debugging port)."
                },
                "antigravityConnector.cdpPortMax": {
                    "type": "number",
                    "default": 9003,
                    "description": "Max CDP port to scan (inclusive)."
                },
                "antigravityConnector.cdpFallbackToUI": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, fall back to UI commands when CDP is unavailable."
                },
                "antigravityConnector.cdpVerifyTimeoutMs": {
                    "type": "number",
                    "default": 2500,
                    "description": "How long to wait for a verification check that the prompt appears in the Agent panel DOM after submit (ms)."
                },
                "antigravityConnector.logFilePath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional: path to a file where the connector OutputChannel is mirrored. If empty, defaults to <workspace>/Local_Agents/Antigravity_POC/data/connector_output.log."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p .",
        "package": "vsce package",
        "watch": "tsc -watch -p .",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@types/node": "^20.14.10",
        "@types/vscode": "^1.90.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eslint": "^8.57.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "@vscode/vsce": "^3.7.1",
        "chrome-remote-interface": "^0.33.0"
    }
}
